    const cx = width / 2, cy = height * 0.52;

    // Seed coat
    this.ctx.fillStyle = '#8D6E63';
    this.ctx.strokeStyle = '#5D4037';
    this.ctx.lineWidth = 2;
    this.ctx.beginPath();
    this.ctx.ellipse(cx, cy, width * 0.36, height * 0.36, 0, 0, Math.PI * 2);
    this.ctx.fill(); this.ctx.stroke();

