    this.ctx.strokeStyle = '#8B6020';
    this.ctx.lineWidth = 1.5;
    this.ctx.beginPath();
    this.ctx.ellipse(cx + width * 0.10, cy, width * 0.06, height * 0.06, 0, 0, Math.PI * 2);
    this.ctx.fill(); this.ctx.stroke();

