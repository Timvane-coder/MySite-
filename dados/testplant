    this.ctx.fillText('Leaf base', cx + width * 0.36, cy + height * 0.12);
    this.ctx.fillStyle = '#7AB840';
    this.ctx.textAlign = 'right';
    this.ctx.fillText('Internode', cx - width * 0.10, height * 0.30);
