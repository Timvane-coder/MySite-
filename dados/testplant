        { label: 'Low turgor', x: width * 0.28, r: 0.14, waterCount: 3, color: '#A5D6A7' },
        { label: 'High turgor', x: width * 0.72, r: 0.20, waterCount: 9, color: '#43A047' }
    ];
    const cy = height * 0.52;

